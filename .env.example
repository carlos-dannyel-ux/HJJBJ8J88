# Configuração de Banco de Dados (Supabase)
# Link de conexão que você encontra em Settings > Database no Supabase
DATABASE_URL=postgresql://postgres.ooxyhlmyefltyrrsxmql:SENHA@aws-1-us-west-1.pooler.supabase.com:6543/postgres

# Chave Secreta para Tokens JWT
